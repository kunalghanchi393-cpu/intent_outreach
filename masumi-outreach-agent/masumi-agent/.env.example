# Intent-Driven Cold Outreach Agent - Masumi Integration
# Copy this file to .env: cp .env.example .env
# Get Masumi credentials from: admin interface

# ============================================
# MASUMI CONFIGURATION (REQUIRED for API mode)
# ============================================
AGENT_IDENTIFIER=
SELLER_VKEY=
PAYMENT_API_KEY=

# ============================================
# OUTREACH SERVICE CONFIGURATION
# ============================================
# URL of the Intent-Driven Cold Outreach Agent service
OUTREACH_SERVICE_URL=http://localhost:3000

# Timeout for outreach processing requests (seconds)
OUTREACH_TIMEOUT=30

# ============================================
# MASUMI OPTIONAL SETTINGS
# ============================================
# Network: Preprod (testnet) or Mainnet (production)
NETWORK=Preprod

# Payment service URL add /api/v1 at the end
PAYMENT_SERVICE_URL=

# Server configuration
#HOST=0.0.0.0
#PORT=8080

# Testing - skip blockchain payments
#MOCK_PAYMENTS=false
