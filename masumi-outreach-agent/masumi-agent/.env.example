# Intent-Driven Cold Outreach Agent - Masumi Integration
# Copy this file to .env: cp .env.example .env
# Get Masumi credentials from: admin interface

# ============================================
# MASUMI CONFIGURATION (REQUIRED)
# ============================================
# REQUIRED: Agent identifier for MIP-003 compliance
# Must be set to a non-empty value (no trailing whitespace)
AGENT_IDENTIFIER=intent-driven-outreach-agent-v1

# REQUIRED: Seller verification key for MIP-003 compliance
# Must be set to a non-empty value (no trailing whitespace)
# Get this from Masumi admin interface
SELLER_VKEY=

# REQUIRED for production: Payment API key
PAYMENT_API_KEY=

# ============================================
# OUTREACH SERVICE CONFIGURATION
# ============================================
# URL of the Intent-Driven Cold Outreach Agent service
OUTREACH_SERVICE_URL=http://localhost:3000

# Timeout for outreach processing requests (seconds)
OUTREACH_TIMEOUT=30

# ============================================
# MASUMI OPTIONAL SETTINGS
# ============================================
# Network: Preprod (testnet) or Mainnet (production)
NETWORK=Preprod

# Payment service URL add /api/v1 at the end
PAYMENT_SERVICE_URL=

# Server configuration
HOST=0.0.0.0  # Use 0.0.0.0 for production, 127.0.0.1 for local only
PORT=8080

# Development/Testing
MOCK_PAYMENTS=false  # Set to true for local testing without blockchain
