# Intent-Driven Cold Outreach Agent - Masumi SDK Configuration
# Copy this file to .env: cp .env.example .env
# Get Masumi credentials from: https://payment-service.masumi.network

# ============================================
# MASUMI SDK REQUIRED CONFIGURATION
# ============================================
# REQUIRED: Agent identifier for MIP-003 compliance
# Must be set to a non-empty value (no trailing whitespace)
AGENT_IDENTIFIER=intent-driven-outreach-agent-v1

# REQUIRED: Seller verification key from Masumi payment service UI
# Get this from: https://payment-service.masumi.network or your Masumi admin interface
SELLER_VKEY=

# REQUIRED: Seller secret key for Ed25519 signing (SDK handles signing automatically)
# Keep this secure and never commit to version control
SELLER_SKEY=

# REQUIRED for production: Payment API key from Masumi service
# Used to authenticate with Masumi Payment Service
PAYMENT_API_KEY=

# REQUIRED: Payment Service URL (must end with /api/v1)
# Local development: http://localhost:3001/api/v1
# Production: https://payment-service.masumi.network/api/v1
PAYMENT_SERVICE_URL=http://localhost:3001/api/v1

# ============================================
# OUTREACH SERVICE CONFIGURATION
# ============================================
# URL of the Intent-Driven Cold Outreach Agent Node.js service
OUTREACH_SERVICE_URL=http://localhost:3000

# Timeout for outreach processing requests (seconds)
OUTREACH_TIMEOUT=30

# ============================================
# MASUMI OPTIONAL SETTINGS
# ============================================
# Network: Preprod (testnet) or Mainnet (production)
NETWORK=Preprod

# Server configuration (SDK uses these automatically)
HOST=0.0.0.0
PORT=8080
